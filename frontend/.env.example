# ─── Frontend env vars (Vite) ──────────────────────────────────────────────
# Copy this to `.env.local` for local dev. Only `VITE_*` vars are exposed to
# the browser bundle.
#
# On Vercel, set this in: Settings → Environment Variables.
# The value should be the public URL of your deployed backend.

VITE_CALL_ANALYSIS_API_URL=http://localhost:8007
# Example for production:
# VITE_CALL_ANALYSIS_API_URL=https://call-analysis-pipeline-api.onrender.com
