# ─── Required credentials ──────────────────────────────────────────────────
# ElevenLabs Scribe v2 STT. Get from: https://elevenlabs.io/app/account
# Pipeline rotates through up to 4 keys in priority order:
#   ELEVENLABS_API_KEY_4 (newest / Starter plan, tried FIRST)
#   ELEVENLABS_API_KEY_3
#   ELEVENLABS_API_KEY_2
#   ELEVENLABS_API_KEY   (oldest, tried LAST)
# Set whichever you have; missing slots are skipped. The Starter plan key
# (30K credits/month) handles ~17 full 50-call runs comfortably.
ELEVENLABS_API_KEY=
ELEVENLABS_API_KEY_2=
ELEVENLABS_API_KEY_3=
ELEVENLABS_API_KEY_4=

# STT provider toggle. "elevenlabs" (default) or "soniox".
STT_PROVIDER=elevenlabs
SONIOX_API_KEY=

# Azure OpenAI (gpt-4o-mini deployment)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_DEPLOYMENT=gpt-4o-mini

# ─── Server config (defaults are sensible) ─────────────────────────────────
# Port the FastAPI server listens on. Render/Railway/Heroku inject PORT
# automatically; this is the fallback for local dev.
PORT=8007
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins for the frontend.
# Default ("*") is permissive — TIGHTEN THIS IN PRODUCTION.
# Example: ALLOWED_ORIGINS=https://call-analysis.vercel.app,https://your-domain.com
ALLOWED_ORIGINS=*
